# Замени YOUR_VPS_IP на реальный публичный IP твоего VPS
VITE_API_URL=https://YOUR_VPS_IP

# Privacy Mirror — STUN server для WebRTC ICE (UDP порт 3478)
VITE_STUN_URL=stun:YOUR_VPS_IP:3478

# Privacy Mirror — прямой HTTPS для TLS-отпечатка (минует nginx, сохраняет ClientHello)
# Открой этот URL в браузере и прими самоподписанный сертификат перед использованием вкладки TLS
VITE_FINGERPRINT_URL=https://YOUR_VPS_IP:8443
